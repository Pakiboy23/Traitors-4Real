    "framer-motion": "^12.34.3",
    "next": "16.1.6",
    "react": "^19.2.3",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.1.0",
    "pocketbase": "^0.26.8",
    "@tailwindcss/postcss": "^4.2.1",
    "@types/node": "^25.3.2",
