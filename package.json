    "autoprefixer": "^10.4.27",
    "babel-plugin-react-compiler": "^1.0.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.2.2",
    "typescript": "~5.9.3",
    "vite": "^7.3.1"
  }
