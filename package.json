{
  "name": "the-traitors-titanic-swim-team-draft",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:vite": "vite build",
    "build:next": "next build --webpack",
    "start": "next start",
    "dev:vite": "vite",
    "start:vite": "vite preview --host 0.0.0.0 --port $PORT",
    "verify:admin-submissions-merge": "node scripts/verify-admin-submissions-merge.mjs",
    "migrate:legacy-season-shell": "node scripts/migrate-legacy-to-season-shell.mjs",
    "migrate:pocketbase-to-supabase": "node scripts/migrate-pocketbase-to-supabase.mjs",
    "native:web:build": "node scripts/build-native-web.mjs",
    "ios:sync": "npx cap sync ios",
    "ios:sync:bundled": "npm run native:web:build && CAPACITOR_BUNDLED=1 npx cap sync ios",
    "ios:open": "npx cap open ios",
    "android:sync": "npx cap sync android",
    "android:bundle:release": "cd android && ./gradlew bundleRelease",
    "typecheck": "tsc --noEmit",
    "preview": "vite preview"
